rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bookings: anyone can create (public booking form),
    // only authenticated admin can read/update/delete
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Availability: only authenticated admin can read/write
    match /availability/{dateId} {
      allow read: if true;       // public site needs to read availability
      allow write: if request.auth != null;
    }
  }
}
